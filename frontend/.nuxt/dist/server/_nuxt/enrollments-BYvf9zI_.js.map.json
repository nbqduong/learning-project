{"file":"enrollments-BYvf9zI_.js","mappings":";;;;;;;;;;;;;;;;;;AAGA,UAAM,MAAM,OAAA;AACZ,UAAM,OAAO,QAAA;AACb,UAAM,QAAQ,IAAkB,EAAE;AAClC,UAAM,UAAU,IAAI,IAAI;AACxB,UAAM,QAAQ,IAAI,EAAE;AAEpB,QAAI,CAAC,KAAK,WAAW,OAAO;AAC1B,cAAQ,QAAQ;AAChB,YAAM,QAAQ;AAAA,IAChB,OAAO;AACL,UAAI;AACF,cAAM,UAAS,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM,IAAI,gBAAA,CAAgB;AACzC,cAAM,QAAQ,OAAO;AAAA,MACvB,SAAS,KAAU;AACjB,cAAM,QAAQ,KAAK,MAAM,SAAS,KAAK,WAAW;AAAA,MACpD,UAAA;AACE,gBAAQ,QAAQ;AAAA,MAClB;AAAA,IACF;;oBAIQC,eAAAC,WAAA,EAAA,OAAA,EAAA,WAAA,QAAA,aAAA,SAAA,UAAA,SAAA,KAAwD,MAAA,CAAA,+BACxD,EAAA,UAAA,WAAA,CAAyB;UAEpBC,MAAA,OAAA,GAAO;;iBACFA,MAAA,KAAA,GAAK;0CAAE,EAAA,SAAA,UAAA,CAAuB,qBAAIA,MAAA,KAAA,CAAK;;2CAC1C,EAAA,cAAA,QAAA,UAAA,qBAAA,WAAA,aAAA,UAAA,IAAA,CAAmF,CAAA,YAAA;AACzEC,sBAAAD,MAAA,KAAA,IAAR,SAAI;6CAA0B,EAAA,UAAA,UAAA,CAAwB,kBACjDE,eAAA,KAAK,EAAE,gBAAkBA,eAAA,KAAK,SAAS;;;AAE7C,YAAAF,MAAA,KAAA,EAAM,WAAM,GAAA;;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderList","_ssrInterpolate"],"sources":["../../../../pages/me/enrollments.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { Enrollment } from \"~/types/api\";\n\nconst api = useApi();\nconst auth = useAuth();\nconst items = ref<Enrollment[]>([]);\nconst loading = ref(true);\nconst error = ref(\"\");\n\nif (!auth.isLoggedIn.value) {\n  loading.value = false;\n  error.value = \"Login to view your enrollments.\";\n} else {\n  try {\n    const result = await api.listEnrollments();\n    items.value = result.items;\n  } catch (err: any) {\n    error.value = err?.data?.error || err?.message || \"Failed to load enrollments\";\n  } finally {\n    loading.value = false;\n  }\n}\n</script>\n\n<template>\n  <main style=\"padding: 24px; max-width: 900px; margin: 0 auto;\">\n    <h1 style=\"margin: 0 0 16px;\">My Learning</h1>\n\n    <p v-if=\"loading\">Loading...</p>\n    <p v-else-if=\"error\" style=\"color: #b91c1c;\">{{ error }}</p>\n    <ul v-else style=\"background: #fff; border: 1px solid #e5e7eb; padding: 16px 20px; margin: 0;\">\n      <li v-for=\"item in items\" :key=\"item.id\" style=\"margin: 0 0 8px;\">\n        Enrollment {{ item.id }} for course {{ item.course_id }}\n      </li>\n      <li v-if=\"items.length === 0\">No enrollments yet.</li>\n    </ul>\n  </main>\n</template>\n\n"],"version":3}